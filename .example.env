# Required
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
AUTH_SECRET=generate-with-openssl-rand-base64-32

# App URL (emails + links) — set to your deployed URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional — transactional email (logs to console if unset)
RESEND_API_KEY=
ATOMQUEST_EMAIL_FROM=AtomQuest <onboarding@resend.dev>

# Optional — enable email verification + 2FA flows (leave unset for hackathon demo)
# EMAIL_SERVICE=1
